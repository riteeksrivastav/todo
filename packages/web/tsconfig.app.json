{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src"]
}
